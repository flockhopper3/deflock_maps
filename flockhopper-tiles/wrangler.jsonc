{
  "name": "flockhopper-tiles",
  "main": "src/index.js",
  "workers_dev": true,
  "preview_urls": true,
  "compatibility_date": "2026-02-24",
  "routes": [
    {
      "pattern": "tiles.dontgetflocked.com",
      "zone_name": "dontgetflocked.com",
      "custom_domain": true
    }
  ],
  "vars": {
    "ALLOWED_ORIGINS": "*",
    "PMTILES_PATH": "planet.pmtiles"
  },
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "flockhopper-tiles"
    }
  ]
}